            "FromFile": "recolors/{{TargetWithoutPath}}.png",
			"When":  {"Hasmod":"grapeponta.VibrantPastoralRecolor" }},

{   "Action": "EditImage",
			"Patchmode":"Overlay",
            "Target": "Maps/Fall_Xiddav, Maps/fall_Xiddav_Cliffs",
            "FromFile": "recolors/{{TargetWithoutPath}}_{{VPRFall}}.png",
			"When":  {"Hasmod":"grapeponta.VibrantPastoralRecolor" }},
		] }